# Database
DB_URL=jdbc:mysql://localhost:3306/linux_mastery
DB_USERNAME=lm_user
DB_PASSWORD=<generate with: openssl rand -base64 32>
DB_ROOT_PASSWORD=<generate with: openssl rand -base64 32>

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=<generate with: openssl rand -base64 24>

# JWT
JWT_SECRET=<generate with: openssl rand -hex 64>
JWT_REFRESH_SECRET=<generate with: openssl rand -hex 64>
JWT_ACCESS_EXPIRATION_MS=900000
JWT_REFRESH_EXPIRATION_MS=604800000

# Email (password reset) -- use Mailtrap for local dev
SMTP_HOST=sandbox.smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USERNAME=<mailtrap username>
SMTP_PASSWORD=<mailtrap password>

# Docker sandbox
SANDBOX_IMAGE=linux-mastery-sandbox:latest
SANDBOX_IDLE_TIMEOUT_MS=1800000

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173
